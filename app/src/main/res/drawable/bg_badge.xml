<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="0"
                android:startColor="#66EE781F"
                android:centerColor="#44194779"
                android:endColor="#22194779" />
            <stroke
                android:width="1dp"
                android:color="#CCEE781F" />
        </shape>
    </item>
    <item android:left="8dp" android:right="30dp" android:top="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <solid android:color="#22FFFFFF" />
        </shape>
    </item>
</layer-list>
