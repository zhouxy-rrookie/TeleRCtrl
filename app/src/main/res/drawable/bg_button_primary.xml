<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="10dp" />
                    <gradient
                        android:angle="315"
                        android:startColor="#255C96"
                        android:centerColor="#194779"
                        android:endColor="#EE781F" />
                    <stroke
                        android:width="1dp"
                        android:color="#D9FFE3C8" />
                </shape>
            </item>
            <item android:left="10dp" android:right="10dp" android:top="6dp" android:bottom="24dp">
                <shape android:shape="rectangle">
                    <corners android:radius="999dp" />
                    <solid android:color="#40FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="10dp" />
                    <gradient
                        android:angle="315"
                        android:startColor="#D0143557"
                        android:centerColor="#CC194779"
                        android:endColor="#B3EE781F" />
                    <stroke
                        android:width="1dp"
                        android:color="#99EE781F" />
                </shape>
            </item>
            <item android:left="10dp" android:right="10dp" android:top="6dp" android:bottom="26dp">
                <shape android:shape="rectangle">
                    <corners android:radius="999dp" />
                    <solid android:color="#18FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
