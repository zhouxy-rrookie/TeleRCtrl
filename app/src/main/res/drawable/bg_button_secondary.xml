<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="10dp" />
                    <gradient
                        android:angle="315"
                        android:startColor="#3A194779"
                        android:centerColor="#2A12365C"
                        android:endColor="#66EE781F" />
                    <stroke
                        android:width="1dp"
                        android:color="#AAFFD3B0" />
                </shape>
            </item>
            <item android:left="10dp" android:right="10dp" android:top="6dp" android:bottom="24dp">
                <shape android:shape="rectangle">
                    <corners android:radius="999dp" />
                    <solid android:color="#22FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="10dp" />
                    <gradient
                        android:angle="315"
                        android:startColor="#C00A2037"
                        android:centerColor="#B3153960"
                        android:endColor="#AA194779" />
                    <stroke
                        android:width="1dp"
                        android:color="#66EE781F" />
                </shape>
            </item>
            <item android:left="10dp" android:right="10dp" android:top="6dp" android:bottom="26dp">
                <shape android:shape="rectangle">
                    <corners android:radius="999dp" />
                    <solid android:color="#10FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
