<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#334155"
                android:endColor="#0EA5E9" />
            <stroke
                android:width="1dp"
                android:color="#66E2E8F0" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#1F2937"
                android:endColor="#374151" />
            <stroke
                android:width="1dp"
                android:color="#44859BB2" />
        </shape>
    </item>
</selector>
