<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#991B1B"
                android:endColor="#EF4444" />
            <stroke
                android:width="1dp"
                android:color="#99F87171" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#7F1D1D"
                android:endColor="#B91C1C" />
            <stroke
                android:width="1dp"
                android:color="#88FCA5A5" />
        </shape>
    </item>
</selector>
