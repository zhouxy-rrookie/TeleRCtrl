<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="270"
                android:startColor="#34194779"
                android:centerColor="#26153B60"
                android:endColor="#44060F1A" />
            <stroke
                android:width="2dp"
                android:color="#88EE781F" />
        </shape>
    </item>
    <item android:left="10dp" android:right="10dp" android:top="12dp" android:bottom="220dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="0"
                android:startColor="#24FFFFFF"
                android:endColor="#00194779" />
        </shape>
    </item>
</layer-list>
