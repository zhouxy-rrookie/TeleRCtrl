<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#3A194779"
                android:centerColor="#24133554"
                android:endColor="#4206101C" />
            <stroke
                android:width="2dp"
                android:color="#88EE781F" />
        </shape>
    </item>
    <item android:left="10dp" android:right="10dp" android:top="10dp" android:bottom="10dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#44194779" />
        </shape>
    </item>
</layer-list>
