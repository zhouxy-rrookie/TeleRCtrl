<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#B6091524" />
            <stroke
                android:width="1dp"
                android:color="#44EE781F" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <gradient
                android:angle="315"
                android:startColor="#D9102946"
                android:centerColor="#C5163960"
                android:endColor="#BC0A1D34" />
            <stroke
                android:width="1dp"
                android:color="#55194779" />
        </shape>
    </item>
    <item
        android:bottom="42dp"
        android:left="14dp"
        android:right="14dp"
        android:top="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="0"
                android:startColor="#44EE781F"
                android:centerColor="#22194779"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
