<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="0"
                android:startColor="#A0EE781F"
                android:centerColor="#7A8A4619"
                android:endColor="#40194779" />
            <stroke
                android:width="1dp"
                android:color="#CCEE781F" />
        </shape>
    </item>
    <item android:left="8dp" android:right="28dp" android:top="4dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <solid android:color="#20FFFFFF" />
        </shape>
    </item>
</layer-list>
