<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#3A091829" />
            <stroke
                android:width="1dp"
                android:color="#44EE781F" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp" />
            <gradient
                android:angle="0"
                android:startColor="#38194779"
                android:centerColor="#28102A48"
                android:endColor="#2206111F" />
        </shape>
    </item>
    <item
        android:bottom="18dp"
        android:left="10dp"
        android:right="10dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:angle="0"
                android:startColor="#33EE781F"
                android:endColor="#00194779" />
        </shape>
    </item>
</layer-list>
